# Copy this file to config.yaml on the target machine and fill in real values.
# config.yaml is git-ignored.

qijia:
  host: ""           # e.g. "db.internal.example.com"
  port: 5432
  user: ""
  password: ""       # may contain special chars; will be URL-encoded automatically
  database: ""

slack:
  # Slack incoming webhook URL for the funding-top10 daily report. Required.
  webhook: ""
  # Slack channel id (e.g. C05XXXXXXXX). Optional — unused by webhook posts.
  channel: ""

datahub:
  # All three required for haircut lookups. The SDK is installed separately
  # from the alpha repo's vendor dir (see deploy/README).
  prefix: "CYBERX_PROD"                                           # CYBERX_PROD / CYBERX_STAGING / CYBERX_OFFICE / CYBERX_DEV
  api_key: "a98d8d7c83584791b41603a4c4123b5c"                     # tyo prod key — replace for other locations
  gateway_url: "https://nexus.tyo.cyberx.com/nexus-data-hub-gateway/"  # tyo gateway
  # Where the SDK spools downloaded .gz files. "" = ~/.datahub_cache.
  # If corporate AV blocks writes to that path (WinError 5), point this to
  # a folder you know is writable, e.g. "C:\\Users\\you\\Documents\\dhcache".
  cache_dir: ""

# Selection rules. Score = annualized_apr - z * annualized_std
# (one-sided confidence lower bound on annualised funding return). Haircut
# and OI act as hard filters — they don't enter the score itself.
filters:
  min_haircut: 0.5         # drop tokens with haircut < this (NaN dropped too)
  min_oi_usd: 5000000      # drop tokens with OI < this (USD)

score:
  # One-sided z-score for the confidence bound. Larger z = heavier std
  # penalty = more conservative. 1.0 ≈ 84%, 1.645 ≈ 95%, 2.0 ≈ 97.7%.
  confidence_z: 1.645

# Deprecated: composite-rank weights. No longer used. Kept so older configs
# load without error; safe to delete.
score_weights:
  apr7: 0.40
  std: 0.20
  haircut: 0.20
  oi: 0.20

# HTTP/HTTPS proxy URL used for BOTH the Binance API calls and the Slack webhook
# POST (any outbound HTTP). Internal DataHub gateway and DB do NOT go through
# this (they're internal). Empty string = no proxy.
# Example: "http://proxy.company.com:8080"
proxy: ""
